<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="Main_tree">
  <BehaviorTree ID="Main_tree">
    <KeepRunningUntilFailure>
      <ReactiveFallback>
        <Inverter>
          <WriteToBlackboard Hp="{hp}"
                             Enemy_outpost_alive="{enemy_outpost_alive}"
                             Our_outpost_alive="{our_outpost_alive}"
                             Enemy_base_hp="{enemy_base_hp}"
                             Our_base_hp="{our_base_hp}"
                             Sentry_mode="{sentry_mode}"
                             Sentry_buff="{sentry_buff}"/>
        </Inverter>

        <ReactiveSequence>
          <HpCondition Hp="{hp}"/>
          <ReactiveSequence>
            <SetSentryMode mode="defense"
                           mode_topic="{zone_mode_topic}"/>
            <AnnounceBehavior label="低血回家"/>
            <PubNav2Goal goal_pose="{home_position}"
                         frame_id="map"
                         min_pub_interval_ms="500"/>
            <WaitUntilReached goal_pose="{home_position}"
                              tolerance="0.5"/>
          </ReactiveSequence>
        </ReactiveSequence>

        <ReactiveSequence>
          <BaseHpBelowCondition Our_base_hp="{our_base_hp}"
                                threshold="3000"/>
          <ReactiveSequence>
            <SetSentryMode mode="move"
                           mode_topic="{zone_mode_topic}"/>
            <AnnounceBehavior label="回堡垒区"/>
            <FollowWaypointsAction waypoint_file="{fortress_route_csv}"
                                   frame_id="map"/>
            <SetSentryMode mode="attack"
                           mode_topic="{zone_mode_topic}"/>
          </ReactiveSequence>
        </ReactiveSequence>

        <ReactiveSequence>
          <HpAboveCondition Hp="{hp}"
                            threshold="400"/>
          <Sequence>
            <SetSentryMode mode="defense"
                           mode_topic="{zone_mode_topic}"/>
            <AnnounceBehavior label="前场巡逻"/>
            <LoadWaypoints waypoint_file="{front_patrol_csv}"
                           frame_id="map"
                           waypoints="{waypoints}"
                           wait_times="{wait_times}"
                           total_waypoints="{total_wp}"
                           wp_idx="{wp_idx}"/>
            <KeepRunningUntilFailure>
              <Sequence>
                <GetCurrentWaypoint waypoints="{waypoints}"
                                    wait_times="{wait_times}"
                                    wp_idx="{wp_idx}"
                                    current_goal="{current_goal}"
                                    current_wait_sec="{wait_sec}"/>
                <ReactiveSequence>
                  <PubNav2Goal goal_pose="{current_goal}"
                               frame_id="map"
                               min_pub_interval_ms="500"/>
                  <WaitUntilReached goal_pose="{current_goal}"
                                    tolerance="0.5"/>
                </ReactiveSequence>
                <WaitDuration duration_sec="5.0"/>
                <NextWaypoint wp_idx="{wp_idx}"
                              total_waypoints="{total_wp}"/>
              </Sequence>
            </KeepRunningUntilFailure>
          </Sequence>
        </ReactiveSequence>

        <ReactiveSequence>
          <SetSentryMode mode="defense"
                         mode_topic="{zone_mode_topic}"/>
          <AnnounceBehavior label="回家待命"/>
          <PubNav2Goal goal_pose="{home_position}"
                       frame_id="map"
                       min_pub_interval_ms="500"/>
          <WaitUntilReached goal_pose="{home_position}"
                            tolerance="0.5"/>
        </ReactiveSequence>
      </ReactiveFallback>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <TreeNodesModel>
    <Action ID="GetCurrentWaypoint"
            editable="true">
      <input_port name="waypoints"/>
      <input_port name="wait_times"/>
      <input_port name="wp_idx"/>
      <output_port name="current_goal"/>
      <output_port name="current_wait_sec"/>
    </Action>
    <Condition ID="HpCondition"
               editable="true">
      <input_port name="Hp"/>
    </Condition>
    <Condition ID="HpAboveCondition"
               editable="true">
      <input_port name="Hp"/>
      <input_port name="threshold"/>
    </Condition>
    <Condition ID="BaseHpBelowCondition"
               editable="true">
      <input_port name="Our_base_hp"/>
      <input_port name="threshold"/>
    </Condition>
    <Action ID="LoadWaypoints"
            editable="true">
      <input_port name="waypoint_file"/>
      <input_port name="frame_id"/>
      <output_port name="waypoints"/>
      <output_port name="wait_times"/>
      <output_port name="total_waypoints"/>
      <output_port name="wp_idx"/>
    </Action>
    <Action ID="NextWaypoint"
            editable="true">
      <inout_port name="wp_idx"/>
      <input_port name="total_waypoints"/>
    </Action>
    <Action ID="PubNav2Goal"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Action ID="AnnounceBehavior"
            editable="true">
      <input_port name="label"/>
    </Action>
    <Action ID="FollowWaypointsAction"
            editable="true">
      <input_port name="waypoint_file"/>
      <input_port name="frame_id"/>
    </Action>
    <Action ID="SetSentryMode"
            editable="true">
      <input_port name="mode"/>
      <input_port name="mode_topic"/>
    </Action>
    <Action ID="WaitDuration"
            editable="true">
      <input_port name="duration_sec"/>
    </Action>
    <Action ID="WaitUntilReached"
            editable="true">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"/>
    </Action>
    <Action ID="WriteToBlackboard"
            editable="true">
      <output_port name="Hp"/>
      <output_port name="Enemy_outpost_alive"/>
      <output_port name="Our_outpost_alive"/>
      <output_port name="Enemy_base_hp"/>
      <output_port name="Our_base_hp"/>
      <output_port name="Sentry_mode"/>
      <output_port name="Sentry_buff"/>
    </Action>
  </TreeNodesModel>
</root>
